{
  "name": "digital-pandharpur",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --accept-data-loss && bun run db:seed && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "prisma studio",
    "scrape": "bun run src/cli/scrape.ts",
    "scrape:pg": "bun run scripts/scrape-to-postgres.ts",
    "canonical": "bun run src/cli/canonical.ts",
    "enrich": "bun run src/cli/enrich.ts",
    "acquire:all": "bun run src/cli/acquire-all.ts",
    "seed:scaling": "bun run scripts/generate-scaling-data.ts",
    "graph:build": "bun run scripts/build-graph.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@playwright/test": "^1.61.0",
    "@prisma/client": "^5.0.0",
    "@types/three": "^0.184.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "adm-zip": "^0.5.17",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.12.0",
    "meilisearch": "^0.58.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.14",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.61.0",
    "puppeteer-core": "^25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.2",
    "tesseract.js": "^7.0.0",
    "three": "^0.184.0",
    "uuid": "^14.0.0",
    "vis-data": "^8.0.4",
    "vis-network": "^10.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "autoprefixer": "^10.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "postcss": "^8.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
